<!DOCTYPE html>
<html>
<head>
<style>
body {
  font-family: Arial;
  padding: 20px;
}

input {
  width: 300px;
  padding: 8px;
}

button {
  padding: 8px 12px;
  margin-left: 5px;
  cursor: pointer;
}

#response {
  margin-top: 20px;
  white-space: pre-wrap;
}
</style>
</head>

<body>

<h2>Ollama Chat Test</h2>

<input id="prompt" placeholder="Ask Ollama something">
<button onclick="send()">Send</button>

<div id="response">Waiting for response...</div>

<script>
async function send() {
  const prompt = document.getElementById("prompt").value;

  const res = await fetch("https://rapturously-pinnal-reinaldo.ngrok-free.dev/api/generate", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: "qwen3.5",
      prompt: prompt,
      stream: false
    })
  });

  const data = await res.json();

  document.getElementById("response").innerText = data.response;
}
</script>

</body>
</html>
